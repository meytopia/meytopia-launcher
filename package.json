{
  "name": "meytopia-launcher",
  "productName": "Meytopia Launcher",
  "version": "0.0.1",
  "description": "Launcher officiel du serveur Minecraft communautaire Meytopia",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "author": "Meytopia",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "minecraft-java-core": "^4.2.8"
  },
  "build": {
    "appId": "fr.meytopia.launcher",
    "productName": "Meytopia Launcher",
    "files": ["src/**/*", "package.json"],
    "directories": { "output": "dist", "buildResources": "build" },
    "win": { "target": "nsis" },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": true,
      "include": "build/installer.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "meytopia",
      "repo": "meytopia-launcher"
    }
  }
}
